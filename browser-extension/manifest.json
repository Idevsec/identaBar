{
    "manifest_version": 3,
    "name": "IdentaBar",
    "version": "1.0.0",
    "description": "Verify AI Agent identities using the Creduent protocol. See trust badges and cryptographic proofs for any website.",
    "browser_specific_settings": {
        "gecko": {
            "id": "creduent-verifier@idevsec.com",
            "strict_min_version": "109.0",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "permissions": ["activeTab", "storage", "tabs"],
    "host_permissions": ["https://creduent.idevsec.com/*"],
    "icons": {
        "16": "assets/icons/icon16.png",
        "48": "assets/icons/icon48.png",
        "128": "assets/icons/icon128.png"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "assets/icons/icon16.png",
            "48": "assets/icons/icon48.png",
            "128": "assets/icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background/background.js"
    },
    "content_scripts": [
        {
            "matches": ["http://*/*", "https://*/*"],
            "js": ["lib/browser-compat.js", "content/content.js"],
            "run_at": "document_idle"
        }
    ],
    "devtools_page": "devtools/devtools.html"
}
