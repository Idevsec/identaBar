{
    "name": "identabar",
    "displayName": "IdentaBar Client for VS Code",
    "description": "Cryptographic AI Agent identity verifier and attestation gatekeeper using the Creduent protocol.",
    "version": "1.1.1",
    "publisher": "IDevSec",
    "license": "Apache-2.0",
    "icon": "resources/icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/idevsec/IdentaBar.git"
    },
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Other",
        "Linters"
    ],
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "identabar.verifyWorkspace",
                "title": "IdentaBar: Verify Workspace Agents",
                "category": "IdentaBar"
            },
            {
                "command": "identabar.clearCache",
                "title": "IdentaBar: Clear Attestation Cache",
                "category": "IdentaBar"
            },
            {
                "command": "identabar.createAgentIdentity",
                "title": "IdentaBar: Initialize Agent Identity",
                "category": "IdentaBar"
            },
            {
                "command": "identabar.signFile",
                "title": "IdentaBar: Sign File with Agent Key",
                "category": "IdentaBar"
            },
            {
                "command": "identabar.registerDetectedAgent",
                "title": "Register on Creduent",
                "icon": "$(add)",
                "category": "IdentaBar"
            },
            {
                "command": "identabar.configureRegistry",
                "title": "Configure Registry URL",
                "icon": "$(settings-gear)",
                "category": "IdentaBar"
            },
            {
                "command": "identabar.openDocs",
                "title": "Read Creduent Documentation",
                "icon": "$(book)",
                "category": "IdentaBar"
            }
        ],
        "menus": {
            "explorer/context": [
                {
                    "command": "identabar.signFile",
                    "group": "navigation"
                }
            ],
            "view/item/context": [
                {
                    "command": "identabar.registerDetectedAgent",
                    "when": "viewItem == detected-framework",
                    "group": "inline"
                }
            ],
            "view/title": [
                {
                    "command": "identabar.configureRegistry",
                    "when": "view == identabar.registriesView",
                    "group": "navigation"
                }
            ]
        },
        "configuration": {
            "title": "IdentaBar Configuration",
            "properties": {
                "identabar.registryUrl": {
                    "type": "string",
                    "default": "https://creduent.idevsec.com",
                    "description": "The URL of the IDevSec Creduent Registry."
                },
                "identabar.enableAutomaticScanning": {
                    "type": "boolean",
                    "default": true,
                    "description": "Automatically scan the workspace for agent.json files on startup."
                },
                "identabar.attestationStrictness": {
                    "type": "string",
                    "enum": [
                        "strict",
                        "standard",
                        "lax"
                    ],
                    "default": "standard",
                    "description": "strict: Block unsigned agent actions; standard: Warn on missing/expired credentials; lax: Logging only."
                }
            }
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "identabar-explorer",
                    "title": "IdentaBar Explorer",
                    "icon": "resources/icon.svg"
                }
            ]
        },
        "views": {
            "identabar-explorer": [
                {
                    "id": "identabar.agentsView",
                    "name": "Workspace Agents",
                    "icon": "resources/icon.svg"
                },
                {
                    "id": "identabar.frameworksView",
                    "name": "Detected Frameworks",
                    "icon": "resources/icon.svg"
                },
                {
                    "id": "identabar.registriesView",
                    "name": "Registries",
                    "icon": "resources/icon.svg"
                },
                {
                    "id": "identabar.helpView",
                    "name": "Help and Feedback",
                    "icon": "resources/icon.svg"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "node ../sync-shared.js --copy && tsc -p ./ && node -e \"const fs=require('fs');fs.mkdirSync('out/shared',{recursive:true});fs.readdirSync('../shared').forEach(f=>fs.copyFileSync('../shared/'+f,'out/shared/'+f))\"",
        "compile": "node ../sync-shared.js --copy && tsc -p ./ && node -e \"const fs=require('fs');fs.mkdirSync('out/shared',{recursive:true});fs.readdirSync('../shared').forEach(f=>fs.copyFileSync('../shared/'+f,'out/shared/'+f))\"",
        "watch": "node ../sync-shared.js --copy && tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/node": "^20.19.43",
        "@types/vscode": "^1.74.0",
        "typescript": "^6.0.3"
    }
}
